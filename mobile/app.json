{
  "expo": {
    "name": "FakeCheck",
    "slug": "fakecheck",
    "owner": "flossin",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fakecheck",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3148a0de-be57-4d5e-84b4-31faa8cfb587"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "FakeCheck uses the camera to photograph items so they can be identified and authenticity-checked.",
        "NSPhotoLibraryUsageDescription": "FakeCheck imports photos of items you want to check from your library."
      }
    },
    "android": {
      "package": "com.flossinfakecheck.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "apiUrl": "http://localhost:8080",
      "eas": {
        "projectId": "3148a0de-be57-4d5e-84b4-31faa8cfb587"
      }
    }
  }
}
