{
  "expo": {
    "name": "Snap Check",
    "slug": "fakecheck",
    "owner": "flossin",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "snapcheck",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EB"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3148a0de-be57-4d5e-84b4-31faa8cfb587"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Snap Check uses the camera to photograph items so they can be identified and authenticity-checked.",
        "NSPhotoLibraryUsageDescription": "Snap Check imports photos of items you want to check from your library."
      }
    },
    "android": {
      "package": "com.flossinfakecheck.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "apiUrl": "https://fakecheck-production.up.railway.app",
      "eas": {
        "projectId": "3148a0de-be57-4d5e-84b4-31faa8cfb587"
      }
    }
  }
}