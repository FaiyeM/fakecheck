# ===== FakeCheck mobile secrets — copy to mobile.env and fill in =====

# Base URL of the deployed backend (Railway domain from Phase 8).
# For local dev against the dockerized backend, use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=https://<your-app>.up.railway.app

# Optional analytics (Phase 15)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
