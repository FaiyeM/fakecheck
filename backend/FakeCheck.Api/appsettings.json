{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=fakecheck;Username=postgres;Password=dev"
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Swagger": {
    "Enabled": false
  },
  "RateLimit": {
    "GlobalPerDevicePerMinute": 60,
    "VisionPerIpPerMinute": 20
  },
  "Prompts": {
    "Directory": ""
  },
  "Export": {
    "Enabled": true,
    "RunHourUtc": 7,
    "AdminToken": ""
  },
  "R2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "Endpoint": "",
    "BucketScans": "fakecheck-scans",
    "BucketCorrections": "fakecheck-corrections",
    "BucketReference": "fakecheck-reference",
    "PresignTtlMinutes": 15
  },
  "Vision": {
    "MaxAuthCallsPerScan": 8,
    "TimeoutSeconds": 30,
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-flash-latest",
      "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
    },
    "Premium": {
      "Provider": "openai",
      "ApiKey": "",
      "Model": "gpt-4o",
      "BaseUrl": "https://api.openai.com/v1"
    }
  },
  "AllowedHosts": "*"
}
